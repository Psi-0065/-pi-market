# Supabase (프론트엔드에서 사용 - anon key만 사용, service key는 절대 넣지 마세요)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Pi Network (서버 함수 전용 - Vercel 환경변수에만 등록, 절대 커밋 금지)
PI_API_KEY=your-pi-server-api-key

# Supabase 서버 전용 키 (api/pay 함수에서 결제 상태 업데이트용, 절대 커밋 금지)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
VITE_SUPABASE_URL_SERVER=https://your-project.supabase.co
